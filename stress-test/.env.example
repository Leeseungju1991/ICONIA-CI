# ICONIA E2E Wide Stress Test 환경 변수.
# 복사: cp .env.example .env

# === Target ===
# staging | local. production 절대 금지.
STRESS_TARGET=staging

# === Endpoints (target 별 자동 선택) ===
# staging
STAGING_SERVER_BASE=http://iconia-staging-alb.example.com
STAGING_ADMIN_BASE=http://iconia-staging-alb.example.com:8082
STAGING_AI_BASE=http://iconia-staging-alb.example.com:8081

# local (Docker Compose 또는 로컬 dev)
LOCAL_SERVER_BASE=http://localhost:8080
LOCAL_ADMIN_BASE=http://localhost:3000
LOCAL_AI_BASE=http://localhost:8081

# === Auth ===
STRESS_JWT_TOKEN=                  # staging 운영자 JWT — secret. 절대 commit 금지.
STRESS_USER_EMAIL=stress@iconia.dev
STRESS_USER_PASSWORD=

# === Gemini ===
GEMINI_API_KEY=                    # stress test 전용 key (별도 발급 권장)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS_PER_RUN=500000   # 비용 가드 (HD-11)

# === Load Pattern ===
# steady | spike | soak | stress | chaos | burst | retry-storm | queue-saturation | websocket-fanout | ai-concurrency | admin-concurrent | data-consistency | failure-recovery | memory-leak | long-run
STRESS_PATTERN=steady
STRESS_DURATION_S=300              # soak 는 86400 권장
STRESS_RPS_TARGET=100              # peak RPS
STRESS_CONCURRENCY=50              # 동시 worker

# === Virtual Event Simulator ===
VES_NORMAL_RATIO=0.7               # 정상 이벤트 비율
VES_DUPLICATE_RATIO=0.05
VES_MALFORMED_RATIO=0.05
VES_OUT_OF_ORDER_RATIO=0.05
VES_TIMEOUT_RATIO=0.05
VES_BURST_RATIO=0.05
VES_RECONNECT_RATIO=0.03
VES_ABNORMAL_RATIO=0.02

# === Chaos ===
CHAOS_ENABLED=false                # true 시 timeout/latency 주입
CHAOS_TIMEOUT_RATIO=0.02
CHAOS_LATENCY_MS=500
CHAOS_THROTTLE_429_RATIO=0.05

# === Metrics ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
OTEL_COLLECTOR_PORT=4317

# === Report ===
REPORT_OUT_DIR=./reports/output
REPORT_FORMATS=json,csv,html
