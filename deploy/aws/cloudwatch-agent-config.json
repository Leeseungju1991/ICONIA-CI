{
  "_comment": "ICONIA CloudWatch Agent 구성 정본. EC2 user-data 의 amazon-cloudwatch-agent 가 본 파일을 fetch-config 로 적용. log-group 명은 IAM 정책 (terraform/iam.tf 의 CloudWatchLogsAppend) 의 /iconia/${env}/* prefix 와 정합. 운영자가 SSM Parameter Store 'AmazonCloudWatch-iconia-${env}' 에 본 JSON 을 저장한 뒤, EC2 에서 'amazon-cloudwatch-agent-ctl -a fetch-config -m ec2 -c ssm:AmazonCloudWatch-iconia-${env} -s' 로 적용.",
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent",
    "logfile": "/var/log/amazon/amazon-cloudwatch-agent.log"
  },
  "metrics": {
    "namespace": "ICONIA/Host",
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    },
    "aggregation_dimensions": [["InstanceId"], []],
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_iowait", "cpu_usage_user", "cpu_usage_system"],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used_percent", "mem_available"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["used_percent", "inodes_free"],
        "resources": ["/", "/mnt/efs/iconia"],
        "metrics_collection_interval": 60
      },
      "diskio": {
        "measurement": ["io_time", "reads", "writes"],
        "resources": ["*"],
        "metrics_collection_interval": 60
      },
      "net": {
        "measurement": ["bytes_sent", "bytes_recv", "packets_sent", "packets_recv"],
        "resources": ["eth0"],
        "metrics_collection_interval": 60
      },
      "netstat": {
        "measurement": ["tcp_established", "tcp_time_wait"],
        "metrics_collection_interval": 60
      },
      "swap": {
        "measurement": ["swap_used_percent"],
        "metrics_collection_interval": 60
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "_comment": "systemd journal output of iconia-server (StandardOutput=journal -> rsyslog -> /var/log/iconia/server.log 권장. 또는 journalctl -> filebeat 대안 시 본 항목 삭제).",
            "file_path": "/var/log/iconia/server.log",
            "log_group_name": "/iconia/${env}/server",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30,
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/iconia/ai.log",
            "log_group_name": "/iconia/${env}/ai",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30,
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/iconia/admin.log",
            "log_group_name": "/iconia/${env}/admin",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 14,
            "timezone": "UTC"
          },
          {
            "_comment": "nginx access — http 요청 감사. PII (이메일, 전화) 가 query string 에 절대 노출되지 않게 application 측에서 차단. retention 30일.",
            "file_path": "/var/log/nginx/iconia-api.access.log",
            "log_group_name": "/iconia/${env}/nginx-access",
            "log_stream_name": "api-{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/nginx/iconia-ai.access.log",
            "log_group_name": "/iconia/${env}/nginx-access",
            "log_stream_name": "ai-{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/nginx/iconia-admin.access.log",
            "log_group_name": "/iconia/${env}/nginx-access",
            "log_stream_name": "admin-{instance_id}",
            "retention_in_days": 30
          },
          {
            "_comment": "nginx error — 5xx / upstream timeout 진단.",
            "file_path": "/var/log/nginx/iconia-*.error.log",
            "log_group_name": "/iconia/${env}/nginx-error",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 60
          },
          {
            "_comment": "user-data + ec2-pull-and-restart 의 배포 로그. 사고 후 timeline 재구성용.",
            "file_path": "/var/log/iconia-user-data.log",
            "log_group_name": "/iconia/${env}/deploy",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 90
          },
          {
            "_comment": "Audit — application 이 직접 ICONIA/Audit namespace 와 별도로 파일에 sink 하는 경우. 무용 시 제거.",
            "file_path": "/var/log/iconia/audit.log",
            "log_group_name": "/iconia/${env}/audit",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 365,
            "timezone": "UTC"
          }
        ]
      }
    },
    "log_stream_name": "{instance_id}",
    "force_flush_interval": 15
  }
}
