{
  "_comment": "ICONIA-SERVER secret rotation IAM policy. EventBridge / Lambda / GitHub Actions OIDC role attach 용. 작업 4 (secret rotation 자동화).",
  "_scope": [
    "JWT signing key rotation (Secrets Manager PutSecretValue + UpdateSecretVersionStage)",
    "HMAC pepper rotation (동일 권한 + Postgres audit_log 기록)",
    "KMS DEVICE_PROVISIONING_KEK 자동 회전 활성화 (KMS:EnableKeyRotation)",
    "회전 결과 audit_log 작성 권한 (RDS Data API 또는 DB 에 IAM auth)"
  ],
  "_principle": "최소 권한. Resource 와일드카드 절대 금지 — 본 정책의 secret/key ARN 은 운영 시 실제 ARN 으로 envsubst.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerRotateSpecificSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecretVersionStage",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:iconia/prod/jwt-private*",
        "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:iconia/prod/jwt-public*",
        "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:iconia/prod/device-provisioning-hmac-pepper*"
      ]
    },
    {
      "Sid": "KmsAutomaticRotationDeviceProvisioningKek",
      "Effect": "Allow",
      "Action": [
        "kms:EnableKeyRotation",
        "kms:GetKeyRotationStatus",
        "kms:DescribeKey",
        "kms:ListAliases"
      ],
      "Resource": [
        "arn:aws:kms:ap-northeast-2:ACCOUNT_ID:key/DEVICE_PROVISIONING_KEK_KEY_ID"
      ]
    },
    {
      "Sid": "DenyKmsKeyDeletion",
      "Effect": "Deny",
      "Action": [
        "kms:ScheduleKeyDeletion",
        "kms:DisableKeyRotation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsRotationLog",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:ap-northeast-2:ACCOUNT_ID:log-group:/iconia/secret-rotation:*"
      ]
    },
    {
      "Sid": "RdsAuditLogWriteViaIamAuth",
      "Effect": "Allow",
      "Action": [
        "rds-db:connect"
      ],
      "Resource": [
        "arn:aws:rds-db:ap-northeast-2:ACCOUNT_ID:dbuser:DBI_RESOURCE_ID/iconia_rotation_writer"
      ]
    },
    {
      "Sid": "EventBridgeScheduleSelfReadOnly",
      "Effect": "Allow",
      "Action": [
        "events:DescribeRule",
        "scheduler:GetSchedule"
      ],
      "Resource": [
        "arn:aws:events:ap-northeast-2:ACCOUNT_ID:rule/iconia-secret-rotation-*",
        "arn:aws:scheduler:ap-northeast-2:ACCOUNT_ID:schedule/default/iconia-secret-rotation-*"
      ]
    }
  ]
}
