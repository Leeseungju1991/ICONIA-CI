# =============================================================================
# ICONIA-CI — .env.example
#
# 복사 후 `.env` 로 저장하면 AWS 배포 스크립트가 자동 로드한다.
#   PowerShell : Copy-Item .env.example .env
#   bash       : cp .env.example .env
#
# `.env` 는 .gitignore 에 포함 — 절대 커밋되지 않는다.
#
# ICONIA 는 AWS 단일 타겟이다. 모든 서비스(SERVER/AI/ADMIN)는 AWS 실환경을
# 가리키며, APP(Expo) 은 EXPO_PUBLIC_ prefix 로 동일한 AWS endpoint 를 읽는다.
# -----------------------------------------------------------------------------
# 공통
# -----------------------------------------------------------------------------
ICONIA_ENV=prod
AWS_REGION=ap-northeast-2

# ICONIA 모노레포 루트 (1.HW ~ 6.CI 의 부모 폴더).
# 비우면 스크립트가 6.CI 의 두 단계 위를 자동 추정.
#   PowerShell 예: C:\Users\user\Music\ICONIA
ICONIA_REPO_ROOT=

# -----------------------------------------------------------------------------
# 서비스 endpoint (AWS)
# -----------------------------------------------------------------------------
# 모든 클라이언트(SERVER/AI/ADMIN/APP)가 가리키는 AWS 진입점.
# Route53 FQDN(api/ai/admin.<root_domain>) 운영 전까지의 정본 base URL.
ICONIA_SERVER_BASE_URL=http://iconia-prod-alb-1600486872.ap-northeast-2.elb.amazonaws.com

# -----------------------------------------------------------------------------
# AWS 실배포 파라미터
# -----------------------------------------------------------------------------
# terraform output 값으로 채운다 (terraform output -raw <name>).
ICONIA_ARTIFACTS_BUCKET=
# ICONIA_EC2_INSTANCE_ID — PowerShell 의 SSM 배포 target 으로 쓰는 AWS instance-id.
#   * Phase 6 ASG 전환 후에는 ICONIA_ASG_NAME 으로 대체 예정 (docs/scale-up-runbook.md §1.1).
#   * application-side `INSTANCE_ID` (server.js:849 의 claim/lease 표식) 와는 의미가 다르다 —
#     application-side 는 EC2 user-data 가 IMDSv2 로 직접 fetch 해 /etc/iconia.env 에 주입.
#     관련: README.md §6, docs/event-store-cutover.md
ICONIA_EC2_INSTANCE_ID=
ICONIA_ROOT_DOMAIN=

# terraform remote state backend (scripts/bootstrap-aws.ps1 이 생성하는 버킷).
ICONIA_TFSTATE_BUCKET=

# -----------------------------------------------------------------------------
# 내부 서비스 토큰 — AI(3.AI) → Server(2.SERVER) /internal/gemini/usage 보고
# -----------------------------------------------------------------------------
# systemd unit 양쪽이 같은 값을 읽어야 함:
#   - iconia-server.service  (수신: src/routes/internalGeminiRoutes.js, X-Internal-Token 검증)
#   - iconia-ai.service      (발신: src/services/usageReporter.js)
# 권장: AWS SSM Parameter Store SecureString 으로 보관하고 unit ExecStart 직전에
#       `aws ssm get-parameter --with-decryption` 으로 주입 (평문 .env 직접 보관 금지).
# 실토큰 커밋 금지.
INTERNAL_INGEST_TOKEN=
