# =============================================================================
# ICONIA-CI — .env.example
#
# 복사 후 `.env` 로 저장하면 로컬 오케스트레이션 스크립트가 자동 로드한다.
#   PowerShell : Copy-Item .env.example .env
#   bash       : cp .env.example .env
#
# `.env` 는 .gitignore 에 포함 — 절대 커밋되지 않는다.
#
# -----------------------------------------------------------------------------
# 단일 토글 (★ 핵심)
# -----------------------------------------------------------------------------
# DEPLOY_TARGET 한 줄이 "어디서 동작하는가" 를 결정한다.
#   local : localhost 전체 기동 (scripts/local-up.ps1 / local-up.sh)
#   aws   : AWS 실배포 (scripts/build-and-upload.* + trigger-deploy.*)
#
# 다른 레포도 동일 키(DEPLOY_TARGET)를 읽는다 — SERVER/AI/ADMIN 은 DEPLOY_TARGET,
# APP(Expo) 은 EXPO_PUBLIC_ prefix 가 필수라 EXPO_PUBLIC_DEPLOY_TARGET 을 읽는다.
# local 이면 각 서비스가 127.0.0.1 의 sibling 포트를, aws 면 Route53
# FQDN(api/ai/admin.<root_domain>)을 가리킨다.
DEPLOY_TARGET=local

# -----------------------------------------------------------------------------
# 공통
# -----------------------------------------------------------------------------
ICONIA_ENV=dev
AWS_REGION=ap-northeast-2

# ICONIA 모노레포 루트 (1.HW ~ 6.CI 의 부모 폴더).
# 비우면 스크립트가 6.CI 의 두 단계 위를 자동 추정.
#   PowerShell 예: C:\Users\user\Music\ICONIA
ICONIA_REPO_ROOT=

# -----------------------------------------------------------------------------
# [local] localhost 기동 파라미터
# -----------------------------------------------------------------------------
# 로컬 PostgreSQL 16 (Windows 설치판 또는 Docker). local-up 스크립트가 사용.
LOCAL_PG_HOST=127.0.0.1
LOCAL_PG_PORT=5432
LOCAL_PG_USER=iconia
LOCAL_PG_PASSWORD=iconia_local_dev
LOCAL_PG_DATABASE=iconia
# Docker 로 PostgreSQL 을 띄울지 (true), 이미 설치된 로컬 서비스를 쓸지 (false).
LOCAL_PG_USE_DOCKER=true

# 로컬 서비스 포트 — AWS 와 의도적으로 다르다 (로컬 개발 관례).
#   SERVER :8080  AI :3001  ADMIN :3000
# AWS 측 systemd 는 SERVER :8080 / AI :8081 / ADMIN :3000 (nginx 뒤).
LOCAL_SERVER_PORT=8080
LOCAL_AI_PORT=3001
LOCAL_ADMIN_PORT=3000

# 로컬 SERVER 가 AI 를 호출할 때 쓰는 base URL (local-up 이 자동 주입).
LOCAL_AI_BASE_URL=http://127.0.0.1:3001

# 폰(EAS APK) / ESP32 펌웨어가 PC 의 SERVER 를 호출할 때 쓰는 LAN IP.
# - 같은 Wi-Fi 안에서 phone → PC, ESP32 → PC 접근에 필수 (127.0.0.1 은 폰 입장에서 자기 자신).
# - DHCP 가 IP 를 바꾸면 이 한 줄만 갱신하면 local-up.ps1/sh 가 APP env(EXPO_PUBLIC_*) + SERVER
#   CORS_ORIGINS + SERVER_BASE_URL 까지 일괄 재주입한다.
# - 확인 cmd:  (Get-NetIPAddress -AddressFamily IPv4 | Where InterfaceAlias -match 'Wi-Fi|Ethernet').IPAddress
# - 회사 Wi-Fi 의 client/AP isolation 또는 VLAN 분리가 켜져 있으면 핫스팟 필요 (별도).
# - EAS build APK 는 빌드 시점에 굳혀지므로 IP 가 바뀌면 4. APP/eas.json 의 development profile env
#   (EXPO_PUBLIC_API_BASE_URL / EXPO_PUBLIC_PERSONA_AI_BASE_URL / EXPO_PUBLIC_LAN_IP) 도 갱신 + 재빌드.
LOCAL_LAN_IP=192.168.0.30

# -----------------------------------------------------------------------------
# [aws] 실배포 파라미터
# -----------------------------------------------------------------------------
# terraform output 값으로 채운다 (terraform output -raw <name>).
ICONIA_ARTIFACTS_BUCKET=
ICONIA_EC2_INSTANCE_ID=
ICONIA_ROOT_DOMAIN=

# terraform remote state backend (scripts/bootstrap-aws.ps1 이 생성하는 버킷).
ICONIA_TFSTATE_BUCKET=
