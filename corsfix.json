{"commands":["ALB_ORIGIN=\"http://iconia-prod-alb-1600486872.ap-northeast-2.elb.amazonaws.com:8082\"","sed -i \"s|^ADMIN_ALLOWED_ORIGIN=.*|ADMIN_ALLOWED_ORIGIN=$ALB_ORIGIN|\" /etc/iconia.admin.env","sed -i \"s|^CORS_ORIGINS=.*|CORS_ORIGINS=$ALB_ORIGIN|\" /etc/iconia.server.env","echo '--- admin ---'","cat /etc/iconia.admin.env","echo '--- server CORS ---'","grep CORS_ORIGINS /etc/iconia.server.env","systemctl restart iconia-admin iconia-server","sleep 30","systemctl is-active iconia-admin iconia-server","curl -sS -o /dev/null -w 'admin /login -> %{http_code}\\n' http://127.0.0.1:3000/login","curl -sS -o /dev/null -w 'server /health -> %{http_code}\\n' http://127.0.0.1:8080/health"]}
