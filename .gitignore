# Terraform state / runtime
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Secrets in tfvars
*.tfvars
*.tfvars.json
!*.tfvars.example

# 비밀키 / 인증서 / 자격증명 (보안 위생 - 절대 commit 금지)
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.cer
*.crt
secrets/
.aws/credentials
.aws/config

# Build artifacts (스크립트가 만드는 임시 tarball - 로컬 TEMP 에 떨어지지만 안전 차원)
*.tar.gz

# 로컬 환경
.env
.env.*
!.env.example

# 에디터/OS
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Node (혹시 CI 안에 도구가 들어올 경우)
node_modules/
npm-debug.log
yarn-error.log
