{"commands":["systemctl stop iconia-server 2>/dev/null","cd /tmp && openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-priv.pem 2>/dev/null","openssl rsa -in /tmp/jwt-priv.pem -pubout -out /tmp/jwt-pub.pem 2>/dev/null","PRIV=$(awk '{printf \"%s\\\\n\", $0}' /tmp/jwt-priv.pem)","PUB=$(awk '{printf \"%s\\\\n\", $0}' /tmp/jwt-pub.pem)","touch /etc/iconia.server.env","sed -i '/^JWT_PRIVATE_KEY=/d;/^JWT_PUBLIC_KEY=/d' /etc/iconia.server.env","echo \"JWT_PRIVATE_KEY=$PRIV\" >> /etc/iconia.server.env","echo \"JWT_PUBLIC_KEY=$PUB\" >> /etc/iconia.server.env","chown root:iconia /etc/iconia.server.env","chmod 0640 /etc/iconia.server.env","grep -c JWT_ /etc/iconia.server.env","rm /tmp/jwt-priv.pem /tmp/jwt-pub.pem","systemctl reset-failed iconia-server","systemctl restart iconia-server","sleep 25","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 20 --no-pager | tail -20"]}
