{"commands":["systemctl stop iconia-server","ls -d /opt/iconia/server.failed.* 2>/dev/null | sort | tail -1 > /tmp/last_failed","FAILED=$(cat /tmp/last_failed)","echo \"Restoring from: $FAILED\"","[ -n \"$FAILED\" ] && rm -rf /opt/iconia/server && cp -a \"$FAILED\" /opt/iconia/server && chown -R iconia:iconia /opt/iconia/server && echo restored","ls /opt/iconia/server/src/server.js","systemctl reset-failed iconia-server","systemctl restart iconia-server","sleep 45","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 30 --no-pager | tail -30"]}
