{"commands":["systemctl stop iconia-server 2>/dev/null","TOKEN=$(aws secretsmanager get-secret-value --secret-id iconia/prod/redis/auth_token --query SecretString --output text --region ap-northeast-2)","REDIS_URL=\"rediss://default:$TOKEN@master.iconia-prod-redis.jlu545.apn2.cache.amazonaws.com:6379\"","sed -i '/^REDIS_URL=/d' /etc/iconia.server.env","echo \"REDIS_URL=$REDIS_URL\" >> /etc/iconia.server.env","chown root:iconia /etc/iconia.server.env","chmod 0640 /etc/iconia.server.env","grep -c REDIS_URL /etc/iconia.server.env","systemctl reset-failed iconia-server","systemctl restart iconia-server","sleep 25","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 30 --no-pager | tail -30"]}
