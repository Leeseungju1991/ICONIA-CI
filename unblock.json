{"commands":["mkdir -p /etc/systemd/system/iconia-server.service.d /etc/systemd/system/iconia-ai.service.d /etc/systemd/system/iconia-admin.service.d","printf '[Service]\\nMemoryDenyWriteExecute=false\\nEnvironment=\"NODE_OPTIONS=--max-old-space-size=512\"\\n' > /etc/systemd/system/iconia-server.service.d/heap.conf","printf '[Service]\\nMemoryDenyWriteExecute=false\\nEnvironment=\"NODE_OPTIONS=--max-old-space-size=384\"\\n' > /etc/systemd/system/iconia-ai.service.d/heap.conf","printf '[Service]\\nMemoryDenyWriteExecute=false\\nEnvironment=\"NODE_OPTIONS=--max-old-space-size=384\"\\nEnvironment=\"HOSTNAME=0.0.0.0\"\\n' > /etc/systemd/system/iconia-admin.service.d/heap.conf","systemctl daemon-reload","systemctl reset-failed iconia-server iconia-ai iconia-admin","systemctl restart iconia-server","sleep 30","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 20 --no-pager | tail -20"]}
