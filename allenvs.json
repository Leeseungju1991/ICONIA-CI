{"commands":["systemctl stop iconia-server 2>/dev/null","cd /tmp","openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out op-priv.pem 2>/dev/null","openssl rsa -in /tmp/op-priv.pem -pubout -out /tmp/op-pub.pem 2>/dev/null","OPRIV=$(awk '{printf \"%s\\\\n\", $0}' /tmp/op-priv.pem)","OPUB=$(awk '{printf \"%s\\\\n\", $0}' /tmp/op-pub.pem)","rm /tmp/op-priv.pem /tmp/op-pub.pem","DEV_KEY=$(openssl rand -hex 32)","ADM_TOK=$(openssl rand -hex 32)","HMAC_SEC=$(openssl rand -hex 32)","OP_KEK=$(openssl rand -hex 32)","sed -i '/^DEVICE_API_KEY=/d;/^ADMIN_TOKEN=/d;/^CORS_ORIGINS=/d;/^PERSONA_AI_HMAC_SECRET=/d;/^OPERATOR_TOTP_KEK=/d;/^OPERATOR_JWT_PRIVATE_KEY=/d;/^OPERATOR_JWT_PUBLIC_KEY=/d;/^STORAGE_PROVIDER=/d;/^S3_KMS_KEY_ID=/d' /etc/iconia.server.env","{ echo \"DEVICE_API_KEY=$DEV_KEY\"; echo \"ADMIN_TOKEN=$ADM_TOK\"; echo \"CORS_ORIGINS=http://localhost:3000\"; echo \"PERSONA_AI_HMAC_SECRET=$HMAC_SEC\"; echo \"OPERATOR_TOTP_KEK=$OP_KEK\"; echo \"OPERATOR_JWT_PRIVATE_KEY=$OPRIV\"; echo \"OPERATOR_JWT_PUBLIC_KEY=$OPUB\"; echo \"STORAGE_PROVIDER=s3\"; echo \"S3_KMS_KEY_ID=alias/aws/s3\"; } >> /etc/iconia.server.env","chown root:iconia /etc/iconia.server.env","chmod 0640 /etc/iconia.server.env","systemctl reset-failed iconia-server","systemctl restart iconia-server","sleep 30","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 40 --no-pager | tail -40"]}
