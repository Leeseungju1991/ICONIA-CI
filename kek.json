{"commands":["systemctl stop iconia-server 2>/dev/null","KEK=$(openssl rand -hex 32)","PEPPER=$(openssl rand -hex 32)","sed -i '/^DEVICE_PROVISIONING_KEK=/d;/^DEVICE_PROVISIONING_HMAC_PEPPER=/d' /etc/iconia.server.env","echo \"DEVICE_PROVISIONING_KEK=$KEK\" >> /etc/iconia.server.env","echo \"DEVICE_PROVISIONING_HMAC_PEPPER=$PEPPER\" >> /etc/iconia.server.env","chown root:iconia /etc/iconia.server.env","chmod 0640 /etc/iconia.server.env","systemctl reset-failed iconia-server","systemctl restart iconia-server","sleep 25","systemctl is-active iconia-server","curl -sS -o /dev/null -w 'server :8080 -> %{http_code}\\n' http://127.0.0.1:8080/health","journalctl -u iconia-server -n 30 --no-pager | tail -30"]}
